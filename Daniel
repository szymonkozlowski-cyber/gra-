#!/bin/bash
clear
echo "POZIOM 3: Korytarz śmieciowych danych"
echo "Musisz znaleźć plik 'KLUCZ.txt' wśród tysięcy śmieci."
echo "Dostępne pliki: junk1, cache_old, temp_99, KLUCZ.txt, trash_0"

read -p "Wpisz nazwę pliku, który chcesz otworzyć: " file
if [ "$file" == "KLUCZ.txt" ]; then
    echo "Znalazłeś! Kod dostępu do windy to: 1010"
    sleep 2; ./p4.sh
else
    echo "To tylko śmieci... Szukaj dalej."
    sleep 2; ./p3.sh
fi

