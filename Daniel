#!/bin/bash
clear
echo "POZIOM 4: Konsola Zasilania"
echo "Wprowadź sekwencję binarną (4 bity), aby włączyć windę."
echo "(Podpowiedź z poprzedniego poziomu!)"

read -p "Sekwencja: " seq
if [ "$seq" == "1010" ]; then
    echo "Energia płynie do sektora wyjściowego!"
    sleep 2; ./p5.sh
else
    echo "Spięcie! System restartuje konsolę."
    sleep 2; ./p4.sh
fi

