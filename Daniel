#!/bin/bash
clear
echo "POZIOM 1: Cela kwarantanny"
echo "Drzwi są zablokowane. Jak chcesz je otworzyć?"
echo "1) Wytrych (brute-force portów)"
echo "2) Zwarcie (przeciążenie styków)"
echo "3) Logi (szukanie błędu w systemie)"

read -p "Wybór: " opt
case $opt in
    1) echo "Zbyt głośno! Alarm się wzbudził. Spróbuj ponownie."; sleep 2; ./p1.sh ;;
    2) echo "Błysk! Przekaźnik padł. Drzwi stoją otworem!"; ./p2.sh ;;
    3) echo "Znalazłeś lukę w jądrze systemu. Przechodzisz niezauważony!"; ./p2.sh ;;
    *) echo "Niepoprawna opcja."; sleep 1; ./p1.sh ;;
esac

