#!/bin/bash
clear
echo "POZIOM 2: Strażnik Systemowy (Antywirus)"
echo "Skaner wykrył Twoją obecność. Aby go wyłączyć, odgadnij PIN (100-999)."
echo "Podpowiedź: Suma cyfr to 15, a ostatnia cyfra to 5."

while true; do
    read -p "Podaj PIN: " pin
    if [ "$pin" == "735" ] || [ "$pin" == "645" ] || [ "$pin" == "825" ]; then
        echo "Dostęp przyznany. Antywirus przechodzi w tryb uśpienia."
        sleep 2; ./p3.sh; break
    else
        echo "Błędny PIN. Skanowanie w toku..."
    fi
done

