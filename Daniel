#!/bin/bash
clear
echo -e "\e[1;31m!!! ALERT: FIREWALL WYKRYTY !!!\e[0m"
echo "Odpowiedz poprawnie na 3 pytania, inaczej cofniesz się na start poziomu!"

# Pytanie 1
read -p "1. Jaka komenda służy do wyświetlenia plików? " q1
if [ "$q1" != "ls" ]; then ./p5.sh; exit; fi

# Pytanie 2
read -p "2. Jaki protokół działa na porcie 80? " q2
if [ "$q2" != "http" ] && [ "$q2" != "HTTP" ]; then ./p5.sh; exit; fi

# Pytanie 3
