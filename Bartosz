        echo -e "\n\e[32mCzyszczenie przerwane w ostatniej mikrosekundzie! Oddychasz z ulgą...\e[0m"
        sleep 2
        exec ./p30.sh
    else
        echo -e "\n\e[31mZła komenda! System formatuje twój mózg. KONIEC GRY.\e[0m"
        sleep 2
        exit 1
    fi
else
    echo -e "\n\e[31mCZAS MINĄŁ! Fala czyszcząca uderza w ciebie. KONIEC GRY.\e[0m"
    sleep 2
    exit 1
fi
